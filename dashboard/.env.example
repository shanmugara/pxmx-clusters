# Copy to .env and fill in values, then:
#   source .env && python app.py

# GitHub personal access token
# Required scopes: repo (read), actions (read)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your repository in "owner/repo" format
GITHUB_REPO=shanmugara/pxmx-clusters

# Optional: HTTP port (default 5001)
# PORT=5001
