# /etc/pxmx-dashboard/env
# Environment variables loaded by pxmx-dashboard.service.
#
# This file is read by systemd EnvironmentFile= and must use KEY=VALUE syntax
# (no "export", no shell substitution).  Protect it:
#   sudo chown root:pxmx /etc/pxmx-dashboard/env
#   sudo chmod 640 /etc/pxmx-dashboard/env

# ── Required ───────────────────────────────────────────────────────────────────
# GitHub personal access token with repo + actions:read scope
GITHUB_TOKEN=ghp_REPLACE_ME

# Repository in "owner/repo" format
GITHUB_REPO=shanmugara/pxmx-clusters

# ── Optional ───────────────────────────────────────────────────────────────────
# Branch to dispatch workflows against (default: main)
# GITHUB_REF=main

# TCP port Gunicorn binds to (default: 5001)
# PORT=5001

# URL path prefix — set to serve the app under a sub-path (e.g. behind Istio)
# Must start with / and have no trailing slash.  Leave unset to serve at /.
# BASE_PATH=/pxmx

# Number of Gunicorn worker processes (default: 1)
# GUNICORN_WORKERS=1

# Threads per worker (default: 4)
# GUNICORN_THREADS=4

# Log verbosity: debug | info | warning | error | critical (default: info)
# LOG_LEVEL=info
